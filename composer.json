{
    "name": "sympress/profiler",
    "description": "Profiler and web debug toolbar for the WordPress kernel.",
    "type": "wordpress-muplugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Brian Schäffner",
            "email": "brian.schaeffner@sympress.de",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-json": "*",
        "sympress/kernel": "@dev"
    },
    "require-dev": {
        "brain/monkey": "^2.6",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.94",
        "sympress/coding-standards": "@dev",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5",
        "symfony/var-dumper": "^7.3",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "SymPress\\Profiler\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SymPress\\Profiler\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs": [
            "Composer\\Config::disableProcessTimeout",
            "@php bin/package-quality.php cs"
        ],
        "cs:fix": [
            "Composer\\Config::disableProcessTimeout",
            "@php bin/package-quality.php cs:fix"
        ],
        "static-analysis": [
            "Composer\\Config::disableProcessTimeout",
            "@php bin/package-quality.php static-analysis"
        ],
        "tests": [
            "Composer\\Config::disableProcessTimeout",
            "@php bin/package-quality.php tests"
        ],
        "qa": [
            "@cs",
            "@static-analysis",
            "@tests"
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "./../*",
            "options": {
                "symlink": true
            }
        }
    ],
    "extra": {
        "wordpress-install-dir": "vendor/wordpress/wordpress",
        "kernel": {
            "bundle": "SymPress\\Profiler\\ProfilerBundle",
            "entry": "profiler/profiler.php"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
